<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ManiaUtilities.ViewModels"
        x:Class="ManiaUtilities.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Mania Utilities"
        Width="660"
        Height="900"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
    
    <!-- Resources: not rendered content, just definitions available to anything inside this Window -->
    <Window.DataTemplates>
        <DataTemplate DataType="vm:FlnConversionViewModel">
            <Expander Header="{Binding Name}"
                      IsExpanded="{Binding IsExpanded}"
                      Width="600"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Gap (ms)" />
                    <NumericUpDown Value="{Binding GapMs}" />
                </StackPanel>
            </Expander>
        </DataTemplate>
    </Window.DataTemplates>
    
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <StackPanel Margin="30" Spacing="16">
        <!-- Map Information Card -->
        <Grid HorizontalAlignment="Left">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="20,12,12,12">

                <StackPanel Spacing="8" Margin="0,0,0,0" MinWidth="570">
                    <TextBlock Text="{Binding MapTitle}" FontSize="26" Foreground="{StaticResource TextPrimBrush}" />
                    <TextBlock Text="{Binding MapVersion}" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding MapAuthor}" FontSize="16" Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </Border>

            <Rectangle Fill="{StaticResource AccentBrush}"
                       Width="4"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Stretch"
                       RadiusX="0" RadiusY="0" />
        </Grid>
        
        <!-- Presets and Module Options -->
        <DockPanel MinWidth="570" LastChildFill="False">
            <TextBlock Text="Operation Stack"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Foreground="{StaticResource TextMutedBrush}" />

            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right"
                        Spacing="8">

                <!-- Preset Operation Stack -->
                <ComboBox ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberBinding="{Binding Name}"
                          Width="100" />

                <!-- All Available Modules -->
                <ComboBox ItemsSource="{Binding ModuleOptions}"
                          SelectedItem="{Binding SelectedModuleOption}"
                          Width="100" />
            </StackPanel>
        </DockPanel>
        
        <ItemsControl ItemsSource="{Binding OperationStack}"/>
                     
        
    </StackPanel>

</Window>